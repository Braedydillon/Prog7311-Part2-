@model Prog7311_Part2.Models.ServiceRequest

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>
<h4>ServiceRequest</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

           @*  <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <input asp-for="Status" class="form-control" />
                <span asp-validation-for="Status" class="text-danger"></span>
            </div> *@
            <div class="form-group">
                <label class="control-label">Source Currency</label>
                <select name="SourceCurrency" class="form-control" asp-items="ViewBag.Currencies">
                    <option value="USD">USD - US Dollar</option>
                </select>
                <small class="text-muted">Will be converted to ZAR.</small>
            </div>

            <div class="form-group">
                <label asp-for="Cost" class="control-label">Amount (Foreign)</label>
                <input asp-for="Cost" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Cost" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="control-label">Linked Contract Status</label>
                <input id="contractStatusDisplay" class="form-control" readonly style="background-color: #eee;" />
            </div>
            <div class="form-group">
                <label asp-for="ContractId" class="control-label">Contract</label>
                <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractList">
                    <option value="">-- Select Contract --</option>
                </select>
                <span asp-validation-for="ContractId" class="text-danger"></span>
            </div>
            <div class="form-group">
    <label class="control-label">Source Currency</label>
    <select name="SourceCurrency" class="form-control select2" asp-items="ViewBag.Currencies">
        <option value="USD">USD - US Dollar</option> </select>
    <small class="text-muted">The API will convert this value to ZAR automatically.</small>
</div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Use a function so we can run it on page load too
        function updateStatus() {
            var select = document.getElementById('contractSelect');
            var selectedOption = select.options[select.selectedIndex];
            var status = selectedOption.getAttribute('data-status');
            var statusBox = document.getElementById('contractStatusDisplay');

            statusBox.value = status || "";

            if (status === "Expired"||status === "OnHold") {
                statusBox.style.color = "red";
                alert("WARNING: This contract is EXPIRED Or OnHold.");
            } else {
                statusBox.style.color = "black";
            }
        }

        // Change event
        document.getElementById('contractSelect').addEventListener('change', updateStatus);

        // Run on load so if the page reloads with an error, the box fills back up
        window.onload = updateStatus;
    </script>
}