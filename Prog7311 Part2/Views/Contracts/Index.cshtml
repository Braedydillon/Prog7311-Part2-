@model IEnumerable<Prog7311_Part2.Models.Contract>

@using Prog7311_Part2.Models

@{
    ViewData["Title"] = "Index";
}
<div class="card bg-light mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">

            <div class="col-md-3">
                <label class="form-label font-weight-bold">Start Date</label>
                <input type="date" name="startDate" class="form-control" value="@Context.Request.Query["startDate"]" />
            </div>

            <div class="col-md-3">
                <label class="form-label font-weight-bold">End Date</label>
                <input type="date" name="endDate" class="form-control" value="@Context.Request.Query["endDate"]" />
            </div>

            <div class="col-md-3">
                <label class="form-label font-weight-bold">Contract Status</label>
                <select name="status" class="form-control" asp-items="Html.GetEnumSelectList<ContractStatus>()">
                    <option value="">-- All Statuses --</option>
                </select>
            </div>

            <div class="col-md-3">
                <div class="btn-group w-100">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-filter"></i> Filter
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-sync"></i> Clear
                    </a>
                </div>
            </div>

        </form>
    </div>
</div>

<h1 class="display-4">Contracts</h1>
<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Servicelevel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Client)
            </th>
            <th>
                Signed Agreement
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.StartDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndDate)
            </td>
            <td>
                    <span class="badge @(item.Status == ContractStatus.Active ? "bg-success" : "bg-secondary")">
                        @item.Status
                    </span>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Servicelevel)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Client.Name)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ContractId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ContractId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ContractId">Delete</a>
            </td>
            <td>
                    @if (!string.IsNullOrEmpty(item.DocumentPath))
                    {
                        <a href="~/Contracts/@item.DocumentPath" target="_blank" class="btn btn-sm btn-info">
                             View Signed PDF
                        </a>
                        <a href="~/Contracts/@item.DocumentPath"
                           download="@item.DocumentPath"
                           class="btn btn-sm btn-primary">
                             Download
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">No document found</span>
                    }
            </td>
        </tr>
}
    </tbody>
</table>
