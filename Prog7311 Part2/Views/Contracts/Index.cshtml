@model IEnumerable<Prog7311_Part2.Models.Contract>

@using Prog7311_Part2.Models

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Servicelevel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Client)
            </th>
            <th>
                Signed Agreement
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.StartDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndDate)
            </td>
            <td>
                    <span class="badge @(item.Status == ContractStatus.Active ? "bg-success" : "bg-secondary")">
                        @item.Status
                    </span>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Servicelevel)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Client.Name)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ContractId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ContractId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ContractId">Delete</a>
            </td>
            <td>
                    @if (!string.IsNullOrEmpty(item.DocumentPath))
                    {
                        <a href="~/Contracts/@item.DocumentPath"
                           target="_blank"
                           class="btn btn-outline-primary btn-sm">
                            📄 View PDF
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">No document</span>
                    }
            </td>
        </tr>
}
    </tbody>
</table>
